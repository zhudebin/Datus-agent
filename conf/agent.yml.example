agent:
  home: ~/.datus
  # Storage layout (refactored):
  #   * ~/.datus/sessions/{project_name}/        — sessions sharded per project
  #   * ~/.datus/data/                           — storage-backend root; each
  #       backend owns its project isolation (e.g. the built-in sqlite/lance
  #       backends use a ``{project_name}/`` subdirectory, a future Postgres
  #       backend could use a schema name instead)
  #   * ~/.datus/{conf,logs,template,run,...}    — global, shared across projects
  #   * {cwd}/subject/{semantic_models,sql_summaries,ext_knowledge}/ — project KB
  #   * {cwd}/.datus/skills/                     — project-level skills (optional)
  #
  # ``project_name`` is derived from the current working directory (``/`` → ``-``)
  # so every CWD gets its own sessions/data shard without extra configuration.
  # Set ``agent.project_name`` to override — useful when running datus from
  # symlinks, monorepo subdirs, or CI sandboxes that should share the same
  # sessions/data shards.  Must match ``^[a-zA-Z0-9_-]+$`` and be ≤ 200 chars.
  # project_name: my_project
  #
  # LLM configuration layout (v2)
  #
  # - ``agent.providers.<name>`` (preferred)
  #   Provider-level credentials. Configure the API key (or rely on the env
  #   var declared in ``conf/providers.yml``) once per provider; the ``/model``
  #   slash command in the CLI can then switch between any model exposed by
  #   that provider without rewriting YAML. Supported providers (keys) are
  #   shipped in ``conf/providers.yml``: openai, claude, claude_subscription,
  #   codex, deepseek, kimi, qwen, gemini, glm, minimax, alibaba_coding,
  #   glm_coding, minimax_coding, kimi_coding.
  #
  # - ``agent.models.<name>`` (legacy / custom)
  #   Retained for self-hosted or private-deployment models — hand-edit this
  #   section when you need a bespoke base_url / model SKU. The ``/model``
  #   command surfaces entries here under the ``Custom`` group.
  #
  # The active selection lives in ``{project_root}/.datus/config.yml`` as:
  #   target:
  #     provider: openai        # key of agent.providers
  #     model:    gpt-4.1       # concrete SKU
  # or, for a custom entry:
  #   target:
  #     custom: my-internal-model
  # The ``agent.target`` field below is still honored for backwards compat
  # when no project-level override exists.

  providers:
    openai:
      api_key: ${OPENAI_API_KEY}
    claude:
      api_key: ${ANTHROPIC_API_KEY}
    deepseek:
      api_key: ${DEEPSEEK_API_KEY}
    gemini:
      api_key: ${GEMINI_API_KEY}
    # Claude Pro/Max (subscription token via `claude setup-token`, auto-detected).
    claude_subscription:
      auth_type: subscription
    # ChatGPT Plus/Pro (browser OAuth through `datus init`).
    codex:
      auth_type: oauth

  # target: deepseek      # legacy — only read when .datus/config.yml is absent

  # ``models`` is optional; use it for self-hosted or private-deployment
  # endpoints that aren't covered by ``conf/providers.yml``. Each entry has
  # the same shape as before:
  #   <name>:
  #     type: openai            # one of: openai|claude|deepseek|kimi|gemini|...
  #     base_url: https://internal.example.com/v1
  #     api_key: ${MY_KEY}
  #     model: internal-gpt-4
  # models: {}

  # ``nodes.<name>.model`` refers to an entry in ``agent.models`` (custom models
  # only). Leave it empty or omit to inherit whichever provider/model is
  # active according to ``./.datus/config.yml`` + ``agent.providers``.
  nodes:
    schema_linking:
      matching_rate: fast
    generate_sql:
      max_table_schemas_length: 4000
      max_data_details_length: 2000
      max_context_length: 8000
      max_value_length: 500
    reasoning:
      prompt_version: "1.0" # It can be unconfigured, and the latest version is used by default
      max_table_schemas_length: 4000
      max_data_details_length: 2000
      max_context_length: 8000
      max_value_length: 500
    reflect:
      prompt_version: "1.0" # It can be unconfigured, and the latest version is used by default
    output:
      prompt_version: "1.0" # It can be unconfigured, and the latest version is used by default
      check_result: true # Whether to check the results of the previous step, the default value is false
    chat:
      workspace_root: sql2
      max_turns: 25
      prompt_version: "1.0" # It can be unconfigured, and the latest version is used by default

  export:
    max_lines: 1000  # Maximum number of exported data rows, default is 1000
  # Benchmark data is stored at {agent.home}/benchmark/{name}
  # Supported benchmarks: bird_dev, spider2, semantic_layer and other benchmarks you customize
  # Directory structure:
  #   {agent.home}/benchmark/bird/
  #   {agent.home}/benchmark/spider2/
  #   {agent.home}/benchmark/semantic_layer/
  #   {agent.name}/benchmark/{customized_benchmark}

  # Configuration of custom benchmarks
  # benchmark:
  #   my_benchmark:
  #       question_file: dev.json # Relative path to the benchmark question file, can be csv/json/json
  #       question_id_key: question_id # The question id, use the line number when empty; The default value is question_id
  #       db_key: db_id # The key corresponding to database name; By default, the database of namespaces will be taken.
  #       ext_knowledge_key: evidence # Optional, the key corresponding to external knowledge
  #       use_tables_key: tables # Optional: specify which tables to use

  #       # Below is the configuration of the baseline answer to evaluate，if evaluation is not required, you do not need to configure it.
  #       gold_sql_path: "gold/sql" # The standard SQL relative path，Can be a directory ({gold_sql_path}/{task_id}.sql) or json/csv file
  #       gold_sql_key: "" # The key corresponding to the gold SQL.When `gold_sql_path` is a file, this configuration cannot be empty
  #       gold_result_path: "gold/exec_result" # Optional, the standard answer relative path，Can be a directory ({gold_sql_path}/{task_id}.sql) or json/csv file. If not set, gold sql will be executed to obtain the standard answer
  #       gold_result_key: "" # Optional, the key corresponding to the standard answer. When `gold_result_path` is a file, this configuration cannot be empty


  # local databases configuration
  services:
    databases:
      snowflake:
        type: snowflake
        account: ${SNOWFLAKE_ACCOUNT}  # Use environment variables or real values
        username: ${SNOWFLAKE_USER}
        password: ${SNOWFLAKE_PASSWORD}
        # database: BBC
        # schema: BBC_NEWS
      # bird_sqlite: # This section is configured for the bird-dev benchmarking, you should download the database file and unzip it before you can continue
      #   type: sqlite
      #   # just support glob pattern. Ensure that the corresponding database files exist in the configuration directory.
      #   path_pattern: benchmark/bird/dev_20240627/dev_databases/**/*.sqlite # https://bird-bench.oss-cn-beijing.aliyuncs.com/dev.zip
      local_sqlite_ssb:
        type: sqlite
        uri: sqlite:////Users/xxx/benchmark/SSB.db
      local_sqlite2:
        type: sqlite
        uri: sqlite:////Users/xxx/benchmark/SSB.db
      local_duckdb_ssb:
        type: duckdb
        uri: duckdb:////absolute/path/to/db.db # absolute path
      local_duckdb_abc:
        type: duckdb
        uri: duckdb:///relative/path/to/abc.duckdb # relative path
      starrocks:
        type: starrocks
        host: ${STARROCKS_HOST}
        port: ${STARROCKS_PORT}
        username: ${STARROCKS_USER}
        password: ${STARROCKS_PASSWORD}
        database: ${STARROCKS_DATABASE}
    semantic_layer:
      metricflow: {}
    bi_platforms:
      superset:
        type: superset
        api_url: http://localhost:8088
        username: admin
        password: admin
        extra: # Special configurations for different platforms
          provider: db
    schedulers:
      airflow_local:
        name: airflow_local
        type: airflow
        api_base_url: http://localhost:8080/api/v1
        username: ${AIRFLOW_USERNAME}
        password: ${AIRFLOW_PASSWORD}
        dags_folder: /path/to/airflow/dags
        dag_discovery_timeout: 60
        dag_discovery_poll_interval: 5
        # Available Airflow Connection IDs for scheduled jobs.
        # Create these connections in Airflow (Admin > Connections) first,
        # then list them here so the agent knows which conn_id to use.
        connections:
          starrocks_default: "StarRocks production database"
          # pg_analytics: "PostgreSQL analytics warehouse"

  storage:
    # Data path is now fixed at {agent.home}/data
    # Final storage paths: {home}/data/datus_db_{namespace}, {home}/data/sub_agents/{agent_name}, etc.

    # Storage backend configuration
    # The base storage layer is backend-agnostic; concrete implementations are pluggable.
    # rdb:
    #   type: sqlite              # Relational DB backend: sqlite (default)
    # vector:
    #   type: lance               # Vector DB backend: lance (default)

    embedding_device_type: cpu # If set to cpu, it will be specified as cpu, otherwise, it will be automatically selected based on the current machine
    # Local model suggestions:
    # 1. if you want extreme performance, choose the small multilingual model with 384 dimensions: all-MiniLM-L6-v2 (~100M) or intfloat/multilingual-e5-small (~460M).
    # 2. if you want performance and retrieval quality, choose the 1024-dimension multilingual model: intfloat/multilingual-e5-large-instruct (~1.2G)
    # 3. if you pay more attention to retrieval quality, you can choose 1024-dimension model according to language (English/Chinese): BAAI/bge-large-en-v1.5 or BAAI/bge-large-zh-v1.5 (~1.2G)
    # Of course, you can also choose your own model according to your business.
    # If you don't configure the following models, all-MiniLM-L6-v2 will be selected by default.
    # Cloud model suggestions: Now we just support openai.
    database:
      registry_name: openai # default is sentence-transformers
      model_name: text-embedding-v3-small
      dim_size: 1024
      batch_size: 10 # Aliyun only supports no more than 10
      target_model: openai # target model in agent.models, if not set, the agent's target configuration will be used
    document:
      model_name: all-MiniLM-L6-v2 #~100MB The lightest model
      dim_size: 384
    metric:
      model_name: all-MiniLM-L6-v2
      dim_size: 384
    semantic_model:
      model_name: all-MiniLM-L6-v2
      dim_size: 384
    reference_sql:
      model_name: all-MiniLM-L6-v2
      dim_size: 384
    ext_knowledge:
      model_name: all-MiniLM-L6-v2
      dim_size: 384

  workflow:
    plan: planA

    planA:
      - schema_linking
      - generate_sql
      - output

    planB:
      - schema_linking
      - generate_sql
      - execute_sql
      - reflect
      - output

  reflection_nodes:
    schema_linking:
      - schema_linking
      - generate_sql
      - execute_sql
      - reflect
    doc_search:
      - doc_search
      - generate_sql
      - execute_sql
      - reflect
    simple_regenerate:
      - execute_sql
      - reflect
    reasoning:
      - reasoning
      - execute_sql
      - reflect

  # Workflow configuration with parallel execution and selection
  workflow:
    plan: bird_para

    bird_para:
      - schema_linking
      - parallel:
        - generate_sql
        - reasoning
      - selection
      - execute_sql
      - output

  # Sub-workflow example
  workflow:
    plan: bird_para

    bird_para:
      - schema_linking
      - parallel:
        - subworkflow1
        - subworkflow2
        - subworkflow3
      - selection
      - execute_sql
      - output

    subworkflow1:
      - search_metrics
      - generate_sql

    subworkflow2:
      - search_metrics
      - reasoning

    subworkflow3:
      - reasoning
      - reflect

  # Sub-workflow with config example
  workflow:
    plan: bird_para

    bird_para:
      - schema_linking
      - parallel:
        - subworkflow1
        - subworkflow2
        - subworkflow3
      - selection
      - execute_sql
      - output

    subworkflow1:
      steps:
      - search_metrics
      - generate_sql
      config: multi/agent1.yaml

    subworkflow2:
      steps:
      - search_metrics
      - reasoning
      config: multi/agent2.yaml

    subworkflow3:
      steps:
      - reasoning
      - reflect
      config: multi/agent3.yaml

  skills:
    directories:
      - ~/.datus/skills
      - ./skills

  agentic_nodes:
    gen_semantic_model:
      model: anthropic

    gen_metrics:
      model: anthropic
      max_turns: 40
      skills: "gen-metrics"

    gen_sql_summary:
      model: deepseek_v3
      max_turns: 30

    gen_table:
      model: anthropic
      max_turns: 20
      skills: "gen-table"
  # Platform documentation (namespace-independent, stored at {home}/data/document/{platform}/)
  # Each key under 'document' is either a reserved global setting (e.g. tavily_api_key)
  #
  # Common options:
  #   type: github / website / local
  #   source: GitHub repo "owner/repo", website URL, or local path
  #   version: Document version (auto-detected if omitted)
  #   chunk_size: Target chunk size in characters (default: 1024)
  #   include_patterns: File/URL patterns to include (glob for local, regex for website)
  #   exclude_patterns: File/URL patterns to exclude (glob for local, regex for website)
  #
  # GitHub-specific options:
  #   github_token: GitHub API token (falls back to GITHUB_TOKEN env var)
  #   github_ref: Git branch or tag to fetch from (default: default branch)
  #   paths: Paths within the repo to fetch (default: ["docs", "README.md"])
  #
  # Website-specific options:
  #   max_depth: Maximum crawl depth (default: 2)
  #   NOTE: 'paths' is NOT supported for website type. Use include_patterns instead.
  document:
    tavily_api_key: ${TAVILY_API_KEY}
    starrocks:
      type: github
      source: StarRocks/starrocks
      paths: ["docs/sql-reference"] # just for github
      chunk_size: 1024
      github_token: ${GITHUB_TOKEN}
    snowflake:
      type: website
      source: https://docs.snowflake.com/en/
      max_depth: 3
      include_patterns: ["/en/user-guide", "/en/sql-reference"]
    local_docs:
      type: local
      source: /path/to/docs
      include_patterns: ["*.md"]
      exclude_patterns: ["CHANGELOG.md"]
